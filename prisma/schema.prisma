generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  users           User[]
  majorCategories MajorCategory[]
  categories      Category[]
  summaryData     SummaryData[]
  summaryLocks    SummaryLock[]
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  teamId       Int
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  role         String   @default("user") // "superAdmin" | "teamMaster" | "user"
  password     String   @default("NOT_SET")
  mustChangePw Boolean  @default(true)
  createdAt    DateTime @default(now())

  reports      Report[]

  @@unique([teamId, name])
}

model MajorCategory {
  id        Int      @id @default(autoincrement())
  name      String
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  orderIdx  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([teamId, name])
}

model Category {
  id        Int      @id @default(autoincrement())
  major     String
  middle    String
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  orderIdx  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  reportItems ReportItem[]

  @@unique([teamId, major, middle])
}

model Report {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year      Int
  weekNum   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     ReportItem[]

  @@unique([userId, year, weekNum])
  @@index([year, weekNum])
}

model ReportItem {
  id          Int      @id @default(autoincrement())
  reportId    Int
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  currentContents String  @default("[]")
  nextContents    String  @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reportId, categoryId])
  @@index([categoryId])
}

model SummaryData {
  id        Int      @id @default(autoincrement())
  year      Int
  weekNum   Int
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  contents  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, year, weekNum])
}

model SummaryLock {
  id        Int       @id @default(autoincrement())
  year      Int
  weekNum   Int
  teamId    Int
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  isLocked  Boolean   @default(false)
  lockedBy  Int?
  lockedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([teamId, year, weekNum])
}
